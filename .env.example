# Postgres connection string (Neon, Supabase, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/lumiverse"

# Auth: "true" enables email/password login + role enforcement.
# "false" (or unset) runs in local single-user mode with no login.
AUTH_ENABLED="false"

# Cloudflare R2 (S3-compatible). When unset, an in-memory storage client is used.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# Optional: signed download URL TTL in seconds (default 600)
R2_SIGNED_URL_TTL="600"
